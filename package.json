{
  "name": "@crontinel/node",
  "version": "0.1.0",
  "description": "Crontinel monitoring SDK for Node.js applications",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist/",
    "README.md"
  ],
  "scripts": {
    "build": "tsc && node -e \"require('./dist/bundle.cjs')\" 2>/dev/null || true",
    "prepublishOnly": "tsc",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts"
  },
  "keywords": [
    "crontinel",
    "monitoring",
    "cron",
    "laravel",
    "horizon",
    "queue"
  ],
  "author": "Harun R Rayhan",
  "license": "MIT",
  "homepage": "https://crontinel.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/crontinel/node.git"
  },
  "bugs": {
    "url": "https://github.com/crontinel/node/issues"
  },
  "peerDependencies": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "eslint": "^10.2.1",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
  }
}
